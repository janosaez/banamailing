---
---
<section class="cob-section" id="cobranzas">
  <div class="cob-inner">

    <div class="cob-header">
      <div class="cob-eyebrow">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="M8 21h8M12 17v4"/></svg>
        Servicio especializado para empresas
      </div>
      <h2 class="cob-title">Sistema de envíos masivos<br><em>para empresas de cobranzas</em></h2>
      <p class="cob-sub">Envía notificaciones, recordatorios y comunicaciones de cobranza a tu propia base de clientes con <strong>100% de entregabilidad</strong>, usando tu propio dominio y mensajes completamente personalizados por destinatario.</p>
    </div>

    <div class="cob-hero-grid">
      <div class="cob-mockup">
        <div class="cob-email-preview">
          <div class="cob-ep-bar">
            <span class="cob-ep-dot" style="background:#FF5F57"></span>
            <span class="cob-ep-dot" style="background:#FFBD2E"></span>
            <span class="cob-ep-dot" style="background:#28CA41"></span>
            <span class="cob-ep-addr">notificaciones@tuempresa.com.pe</span>
          </div>
          <div class="cob-ep-body">
            <div class="cob-ep-row"><span class="cob-ep-lbl">De:</span><span class="cob-ep-val cob-domain">notificaciones<span class="cob-at">@tuempresa.com.pe</span></span></div>
            <div class="cob-ep-row"><span class="cob-ep-lbl">Para:</span><span class="cob-ep-val">juan.quispe@gmail.com</span></div>
            <div class="cob-ep-row"><span class="cob-ep-lbl">Asunto:</span><span class="cob-ep-val cob-subject">Estimado Juan, recordatorio de pago — Cuota #3</span></div>
            <div class="cob-ep-divider"></div>
            <div class="cob-ep-content">
              <p class="cob-ep-greeting">Estimado <strong>Juan Carlos Quispe</strong>,</p>
              <p class="cob-ep-text">Le recordamos que tiene una cuota pendiente de <strong>S/ 450.00</strong> con vencimiento el <strong>25 de abril de 2026</strong>. Por favor regularice su situación para evitar cargos adicionales.</p>
              <div class="cob-ep-btn">Regularizar ahora →</div>
              <p class="cob-ep-footer">Empresa Financiera Perú S.A. · Expediente #00234-2026</p>
            </div>
          </div>
        </div>
        <div class="cob-mockup-label">Vista real del correo recibido por el cliente</div>
      </div>

      <div class="cob-kpis">
        <div class="cob-kpi cob-kpi-main">
          <span class="cob-kpi-num">100%</span>
          <span class="cob-kpi-label">Entregabilidad garantizada</span>
          <span class="cob-kpi-hint">Con tu propio dominio, IPs dedicadas y autenticación SPF/DKIM/DMARC</span>
        </div>
        <div class="cob-kpi">
          <span class="cob-kpi-num" style="color:var(--purple)">∞</span>
          <span class="cob-kpi-label">Personalización por destinatario</span>
          <span class="cob-kpi-hint">Nombre, monto, fecha, expediente, producto — cada correo es único</span>
        </div>
        <div class="cob-kpi">
          <span class="cob-kpi-num" style="color:#16A34A">📊</span>
          <span class="cob-kpi-label">Estadísticas en tiempo real</span>
          <span class="cob-kpi-hint">Aperturas, clics, rebotes y conversiones en tu dashboard</span>
        </div>
        <div class="cob-kpi">
          <span class="cob-kpi-num" style="color:#0EA5E9">🏢</span>
          <span class="cob-kpi-label">Tu dominio, tu identidad</span>
          <span class="cob-kpi-hint">Los correos salen desde @tuempresa.com.pe — máxima confianza</span>
        </div>
      </div>
    </div>

    <div class="cob-features">
      <div class="cob-feat-header">
        <h3 class="cob-feat-title">¿Qué incluye el sistema?</h3>
      </div>
      <div class="cob-feat-grid">
        <div class="cob-feat-card">
          <div class="cob-feat-icon">🏷️</div>
          <h4 class="cob-feat-name">Dominio propio de la empresa</h4>
          <p class="cob-feat-desc">Configuramos tu dominio corporativo para que los envíos salgan desde <em>@tuempresa.com.pe</em>. Esto genera confianza inmediata en el destinatario y evita que caiga en spam.</p>
        </div>
        <div class="cob-feat-card">
          <div class="cob-feat-icon">👤</div>
          <h4 class="cob-feat-name">Mensajes 100% personalizados</h4>
          <p class="cob-feat-desc">Cada correo incluye el nombre del deudor, monto adeudado, fecha de vencimiento, número de expediente y cualquier variable que necesites desde tu base de datos.</p>
        </div>
        <div class="cob-feat-card">
          <div class="cob-feat-icon">📈</div>
          <h4 class="cob-feat-name">Estadísticas detalladas</h4>
          <p class="cob-feat-desc">Dashboard con métricas en tiempo real: tasa de apertura, clics en links de pago, rebotes duros y blandos, bajas y conversiones por campaña.</p>
        </div>
        <div class="cob-feat-card">
          <div class="cob-feat-icon">🔒</div>
          <h4 class="cob-feat-name">Alta entregabilidad garantizada</h4>
          <p class="cob-feat-desc">IPs dedicadas, autenticación SPF, DKIM y DMARC correctamente configurados. Tus correos llegan a la bandeja principal, no al spam ni a promociones.</p>
        </div>
        <div class="cob-feat-card">
          <div class="cob-feat-icon">⚡</div>
          <h4 class="cob-feat-name">Envío a tu propia base</h4>
          <p class="cob-feat-desc">Usamos exclusivamente tu base de datos de clientes. No compartimos, no mezclamos ni usamos datos de terceros. Tu cartera es 100% tuya.</p>
        </div>
        <div class="cob-feat-card">
          <div class="cob-feat-icon">🔄</div>
          <h4 class="cob-feat-name">Automatización y secuencias</h4>
          <p class="cob-feat-desc">Programa recordatorios automáticos: 30 días antes del vencimiento, el día del vencimiento y seguimientos post-mora con diferentes tonos de comunicación.</p>
        </div>
      </div>
    </div>

    <div class="cob-for-wrap">
      <h3 class="cob-for-title">Ideal para</h3>
      <div class="cob-for-grid">
        <div class="cob-for-pill">🏦 Financieras y bancos</div>
        <div class="cob-for-pill">📱 Empresas de telecomunicaciones</div>
        <div class="cob-for-pill">🏥 Clínicas y seguros de salud</div>
        <div class="cob-for-pill">🛒 Retail y tiendas por departamento</div>
        <div class="cob-for-pill">🏢 Gestoras de cobranza</div>
        <div class="cob-for-pill">🏗️ Inmobiliarias y constructoras</div>
        <div class="cob-for-pill">⚡ Empresas de servicios públicos</div>
        <div class="cob-for-pill">📦 Empresas de leasing y crédito</div>
      </div>
    </div>

    <div class="cob-cta-block">
      <div class="cob-cta-left">
        <h3 class="cob-cta-title">¿Tu empresa necesita este sistema?</h3>
        <p class="cob-cta-desc">Cuéntanos el volumen de tu cartera, la frecuencia de envío y te preparamos una propuesta a medida en menos de 24 horas. Sin compromiso.</p>
        <div class="cob-cta-form" id="cobCtaForm">
          <div class="cob-form-row">
            <input class="field-input" id="cobEmpresa" type="text" placeholder="Nombre de tu empresa *" />
            <input class="field-input" id="cobTel" type="tel" placeholder="WhatsApp *" />
          </div>
          <div class="cob-form-row">
            <input class="field-input" id="cobEmail" type="email" placeholder="Correo corporativo *" />
            <input class="field-input" id="cobVolumen" type="text" placeholder="Volumen mensual aprox. (registros)" />
          </div>
          <button class="cob-submit-btn" onclick="handleCobSubmit()">
            <svg width="16" height="16" viewBox="0 0 32 32" fill="currentColor" aria-hidden="true"><path d="M16 .5C7.44.5.5 7.44.5 16c0 2.83.74 5.48 2.04 7.78L.5 31.5l7.93-2.07A15.45 15.45 0 0016 31.5C24.56 31.5 31.5 24.56 31.5 16S24.56.5 16 .5zm7.58 18.14c-.41-.2-2.44-1.2-2.82-1.34-.38-.14-.65-.2-.93.2-.28.41-1.07 1.34-1.31 1.62-.24.27-.48.31-.9.1-.41-.2-1.74-.64-3.32-2.04a12.4 12.4 0 01-2.3-2.85c-.24-.41-.03-.63.18-.84.19-.18.41-.48.62-.72.2-.24.27-.41.41-.69.14-.27.07-.52-.03-.72-.1-.2-.93-2.24-1.28-3.07-.33-.8-.67-.69-.93-.7h-.79c-.27 0-.72.1-1.1.52-.38.41-1.44 1.41-1.44 3.44s1.48 3.99 1.69 4.27c.2.27 2.9 4.43 7.04 6.21.98.42 1.75.68 2.35.87.99.31 1.88.27 2.59.16.79-.12 2.44-1 2.78-1.96.34-.96.34-1.78.24-1.96-.1-.18-.38-.27-.79-.48z"/></svg>
            Solicitar propuesta a medida →
          </button>
        </div>
        <div id="cobSuccess" style="display:none" class="success-msg">
          <div class="success-icon" style="background:#EDE9FF;color:#674CC4;">✓</div>
          <p class="success-title">¡Consulta enviada!</p>
          <p class="success-desc">Te abrimos WhatsApp ahora mismo. Un especialista te contactará en menos de 24 horas con una propuesta personalizada.</p>
        </div>
      </div>
      <div class="cob-cta-right">
        <div class="cob-guarantee-card">
          <div class="cob-g-icon">🛡️</div>
          <h4 class="cob-g-title">Garantías del servicio</h4>
          <ul class="cob-g-list">
            <li><span class="vchk" style="background:#EDE9FF;color:#674CC4;">✓</span>100% de entregabilidad con tu dominio</li>
            <li><span class="vchk" style="background:#EDE9FF;color:#674CC4;">✓</span>Configuración SPF, DKIM y DMARC incluida</li>
            <li><span class="vchk" style="background:#EDE9FF;color:#674CC4;">✓</span>Personalización ilimitada de variables</li>
            <li><span class="vchk" style="background:#EDE9FF;color:#674CC4;">✓</span>Dashboard de estadísticas en tiempo real</li>
            <li><span class="vchk" style="background:#EDE9FF;color:#674CC4;">✓</span>Soporte dedicado durante la campaña</li>
            <li><span class="vchk" style="background:#EDE9FF;color:#674CC4;">✓</span>Confidencialidad total de tu base de datos</li>
          </ul>
        </div>
        <div class="cob-wa-block">
          <div class="wa-orb">
            <svg viewBox="0 0 32 32" width="20" height="20" fill="white" aria-hidden="true"><path d="M16 .5C7.44.5.5 7.44.5 16c0 2.83.74 5.48 2.04 7.78L.5 31.5l7.93-2.07A15.45 15.45 0 0016 31.5C24.56 31.5 31.5 24.56 31.5 16S24.56.5 16 .5zm7.58 18.14c-.41-.2-2.44-1.2-2.82-1.34-.38-.14-.65-.2-.93.2-.28.41-1.07 1.34-1.31 1.62-.24.27-.48.31-.9.1-.41-.2-1.74-.64-3.32-2.04a12.4 12.4 0 01-2.3-2.85c-.24-.41-.03-.63.18-.84.19-.18.41-.48.62-.72.2-.24.27-.41.41-.69.14-.27.07-.52-.03-.72-.1-.2-.93-2.24-1.28-3.07-.33-.8-.67-.69-.93-.7h-.79c-.27 0-.72.1-1.1.52-.38.41-1.44 1.41-1.44 3.44s1.48 3.99 1.69 4.27c.2.27 2.9 4.43 7.04 6.21.98.42 1.75.68 2.35.87.99.31 1.88.27 2.59.16.79-.12 2.44-1 2.78-1.96.34-.96.34-1.78.24-1.96-.1-.18-.38-.27-.79-.48z"/></svg>
          </div>
          <div class="wa-info"><p class="wa-label">Consulta directa</p><p class="wa-num">+51 990 137 226</p></div>
          <a href="https://api.whatsapp.com/send?phone=51990137226&text=Hola%2C%20me%20interesa%20el%20sistema%20de%20env%C3%ADos%20masivos%20para%20cobranzas." target="_blank" class="wa-link-btn">WhatsApp</a>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  .cob-section {
    background: #fff;
    padding: 3.5rem 4rem;
  }
  .cob-inner { max-width: 1180px; margin: 0 auto; }

  .cob-header { text-align: center; margin-bottom: 4rem; }
  .cob-eyebrow {
    display: inline-flex; align-items: center; gap: 7px;
    background: #FEF3E2; color: #C2410C;
    border: 1px solid #FED7AA;
    font-size: 12px; font-weight: 700;
    padding: 5px 16px; border-radius: 100px;
    margin-bottom: 1.25rem;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .cob-title {
    font-size: clamp(1.9rem, 3.2vw, 2.9rem);
    font-weight: 900; letter-spacing: -0.035em;
    color: var(--text); line-height: 1.1; margin-bottom: 1rem;
  }
  .cob-title em { color: var(--purple); font-style: normal; }
  .cob-sub {
    font-size: 1.05rem; color: var(--muted);
    max-width: 680px; margin: 0 auto; line-height: 1.7;
  }
  .cob-sub strong { color: var(--text); font-weight: 700; }

  .cob-hero-grid {
    display: grid; grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem; align-items: start; margin-bottom: 4rem;
  }

  .cob-email-preview {
    background: #fff; border: 1px solid #E5E7EB;
    border-radius: 16px; overflow: hidden;
    box-shadow: 0 8px 40px rgba(0,0,0,0.1);
  }
  .cob-ep-bar {
    background: #F3F4F6; padding: 10px 14px;
    display: flex; align-items: center; gap: 6px;
  }
  .cob-ep-dot { width: 10px; height: 10px; border-radius: 50%; }
  .cob-ep-addr {
    margin-left: 10px; font-size: 11.5px; color: #6B7280;
    font-weight: 500; background: #fff;
    padding: 3px 10px; border-radius: 100px;
    border: 1px solid #E5E7EB;
  }
  .cob-ep-body { padding: 1.25rem 1.5rem; }
  .cob-ep-row {
    display: flex; align-items: baseline; gap: 8px;
    font-size: 12.5px; margin-bottom: 5px;
  }
  .cob-ep-lbl { color: #9CA3AF; font-weight: 600; width: 44px; flex-shrink: 0; }
  .cob-ep-val { color: var(--text); font-weight: 500; }
  .cob-domain { color: var(--purple); font-weight: 700; }
  .cob-at { color: var(--muted); }
  .cob-subject { color: var(--text); font-weight: 700; }
  .cob-ep-divider { height: 1px; background: #F3F4F6; margin: 1rem 0; }
  .cob-ep-content { font-size: 13px; line-height: 1.7; color: #374151; }
  .cob-ep-greeting { margin-bottom: 8px; font-size: 13.5px; }
  .cob-ep-text { margin-bottom: 1rem; }
  .cob-ep-btn {
    display: inline-block;
    background: var(--purple); color: #fff;
    padding: 10px 22px; border-radius: 8px;
    font-size: 13px; font-weight: 700; margin-bottom: 1rem;
    cursor: default;
  }
  .cob-ep-footer { font-size: 11px; color: #9CA3AF; border-top: 1px solid #F3F4F6; padding-top: 10px; }
  .cob-mockup-label {
    text-align: center; font-size: 12px; color: #9CA3AF;
    margin-top: 10px; font-weight: 500;
  }

  .cob-kpis { display: flex; flex-direction: column; gap: 14px; }
  .cob-kpi {
    background: #F8F7FF; border: 1px solid #EDE9FF;
    border-radius: 14px; padding: 1.1rem 1.25rem;
    display: flex; flex-direction: column; gap: 3px;
    transition: transform 0.2s, box-shadow 0.2s;
  }
  .cob-kpi:hover { transform: translateX(4px); box-shadow: 0 4px 16px rgba(103,76,196,0.1); }
  .cob-kpi-main { background: var(--purple); border-color: var(--purple); }
  .cob-kpi-num {
    font-size: 2rem; font-weight: 900;
    color: var(--purple); letter-spacing: -0.04em; line-height: 1;
  }
  .cob-kpi-main .cob-kpi-num { color: #fff; }
  .cob-kpi-label { font-size: 13px; font-weight: 700; color: var(--text); }
  .cob-kpi-main .cob-kpi-label { color: #fff; }
  .cob-kpi-hint { font-size: 11.5px; color: var(--muted); line-height: 1.4; }
  .cob-kpi-main .cob-kpi-hint { color: rgba(255,255,255,0.7); }

  .cob-features { margin-bottom: 4rem; }
  .cob-feat-header { margin-bottom: 1.75rem; }
  .cob-feat-title {
    font-size: 1.5rem; font-weight: 900;
    letter-spacing: -0.03em; color: var(--text);
  }
  .cob-feat-grid {
    display: grid; grid-template-columns: repeat(3,1fr); gap: 1.25rem;
  }
  .cob-feat-card {
    background: #F8F7FF; border: 1px solid #EDE9FF;
    border-radius: 16px; padding: 1.5rem 1.25rem;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .cob-feat-card:hover {
    transform: translateY(-4px); border-color: #DDD6FE;
    box-shadow: 0 10px 30px rgba(103,76,196,0.1);
  }
  .cob-feat-icon { font-size: 26px; margin-bottom: 0.8rem; }
  .cob-feat-name { font-size: 14px; font-weight: 800; color: var(--text); margin-bottom: 6px; letter-spacing: -0.01em; }
  .cob-feat-desc { font-size: 12.5px; color: var(--muted); line-height: 1.65; }
  .cob-feat-desc em { color: var(--purple); font-style: normal; font-weight: 600; }

  .cob-for-wrap { margin-bottom: 4rem; text-align: center; }
  .cob-for-title { font-size: 1.3rem; font-weight: 800; color: var(--text); margin-bottom: 1.25rem; letter-spacing: -0.02em; }
  .cob-for-grid { display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; }
  .cob-for-pill {
    background: #fff; border: 1px solid var(--border);
    border-radius: 100px; padding: 9px 18px;
    font-size: 13px; font-weight: 600; color: var(--text);
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
    cursor: default;
  }
  .cob-for-pill:hover { border-color: var(--purple); background: var(--purple-light); transform: translateY(-2px); }

  .cob-cta-block {
    display: grid; grid-template-columns: 1.2fr 0.8fr;
    gap: 3rem; align-items: start;
    background: #F8F7FF; border: 1px solid #EDE9FF;
    border-radius: 22px; padding: 2.5rem;
  }
  .cob-cta-title { font-size: 1.4rem; font-weight: 900; color: var(--text); letter-spacing: -0.03em; margin-bottom: 0.75rem; }
  .cob-cta-desc { font-size: 14px; color: var(--muted); line-height: 1.65; margin-bottom: 1.5rem; }
  .cob-cta-form { display: flex; flex-direction: column; gap: 10px; }
  .cob-form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 10px; }
  .cob-submit-btn {
    width: 100%; padding: 14px;
    background: var(--purple); color: #fff; border: none;
    border-radius: 11px; font-size: 14px; font-weight: 700;
    font-family: inherit; cursor: pointer;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 4px 16px rgba(103,76,196,0.28); margin-top: 4px;
  }
  .cob-submit-btn:hover { background: var(--purple-dark); transform: translateY(-2px); box-shadow: 0 8px 24px rgba(103,76,196,0.38); }

  .cob-guarantee-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 16px; padding: 1.5rem; margin-bottom: 14px;
  }
  .cob-g-icon { font-size: 26px; margin-bottom: 0.6rem; }
  .cob-g-title { font-size: 14px; font-weight: 800; color: var(--text); margin-bottom: 1rem; }
  .cob-g-list { list-style: none; display: flex; flex-direction: column; gap: 9px; }
  .cob-g-list li { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--text); }
  .cob-wa-block {
    display: flex; align-items: center; gap: 10px;
    background: #F0FDF4; border: 1px solid #BBF7D0;
    border-radius: 12px; padding: 12px 14px;
  }

  @media (max-width: 900px) {
    .cob-section { padding: 2.5rem 1.5rem; }
    .cob-hero-grid { grid-template-columns: 1fr; }
    .cob-feat-grid { grid-template-columns: 1fr; }
    .cob-cta-block { grid-template-columns: 1fr; }
    .cob-form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  (window as any).handleCobSubmit = function() {
    const empresa  = (document.getElementById('cobEmpresa')  as HTMLInputElement)?.value || '';
    const tel      = (document.getElementById('cobTel')      as HTMLInputElement)?.value || '';
    const email    = (document.getElementById('cobEmail')    as HTMLInputElement)?.value || '';
    const volumen  = (document.getElementById('cobVolumen')  as HTMLInputElement)?.value || '';
    if (!empresa || !tel || !email) {
      alert('Completa los campos obligatorios (empresa, WhatsApp y correo).');
      return;
    }
    const msg = `🏢 *SISTEMA DE ENVÍOS MASIVOS PARA COBRANZAS — BanaMailing*\n\n` +
      `🏢 *Empresa:* ${empresa}\n📱 *WhatsApp:* ${tel}\n📧 *Correo:* ${email}\n` +
      (volumen ? `📊 *Volumen mensual:* ${volumen} registros\n` : '') +
      `\n_Solicito información sobre el sistema de envíos masivos personalizados para cobranzas con dominio propio._`;
    const url = `https://api.whatsapp.com/send?phone=51990137226&text=${encodeURIComponent(msg)}`;
    const success = document.getElementById('cobSuccess');
    const form = document.getElementById('cobCtaForm');
    if (success) success.style.display = 'block';
    if (form) form.style.display = 'none';
    setTimeout(() => window.open(url, '_blank'), 600);
  };
</script>
