<section class="contact-section">
  <div class="contact-inner">

    <!-- Header -->
    <div class="contact-header">
      <div class="contact-eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
        Hablemos hoy mismo
      </div>
      <h1 class="contact-title">Contáctanos y<br><em>te respondemos en 2 horas</em></h1>
      <p class="contact-sub">Nuestro equipo está listo para ayudarte con tu campaña de correos masivos, resolver dudas o armar una propuesta a medida para tu empresa.</p>
    </div>

    <!-- Grid: Form + Info -->
    <div class="contact-grid">

      <!-- Form -->
      <div class="contact-form-card">
        <h2 class="cfc-title">Envíanos un mensaje</h2>
        <p class="cfc-sub">Completa el formulario y te contactamos por WhatsApp o correo.</p>

        <div class="form-body" id="contactFormBody">
          <div class="field-row">
            <div class="field-group">
              <label class="field-label">Nombre <span class="req">*</span></label>
              <input class="field-input" id="cNombre" type="text" placeholder="Tu nombre completo" />
            </div>
            <div class="field-group">
              <label class="field-label">Empresa</label>
              <input class="field-input" id="cEmpresa" type="text" placeholder="Nombre de tu empresa" />
            </div>
          </div>
          <div class="field-row">
            <div class="field-group">
              <label class="field-label">Correo electrónico <span class="req">*</span></label>
              <input class="field-input" id="cEmail" type="email" placeholder="tu@empresa.com" />
            </div>
            <div class="field-group">
              <label class="field-label">Teléfono / WhatsApp <span class="req">*</span></label>
              <input class="field-input" id="cTel" type="tel" placeholder="+51 9XX XXX XXX" />
            </div>
          </div>
          <div class="field-group">
            <label class="field-label">Servicio de interés</label>
            <select class="field-input" id="cServicio">
              <option value="">Selecciona una opción…</option>
              <option>Correos masivos / Email marketing</option>
              <option>Validación de base de correos</option>
              <option>Sistema de cobranzas por email</option>
              <option>Demo gratuita de campaña</option>
              <option>Consulta general</option>
            </select>
          </div>
          <div class="field-group">
            <label class="field-label">Mensaje <span class="req">*</span></label>
            <textarea class="field-textarea" id="cMensaje" rows="4" placeholder="Cuéntanos qué necesitas, cuántos correos tienes, tu rubro…"></textarea>
          </div>

          <button class="contact-submit-btn" id="contactSubmitBtn" type="button">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/></svg>
            Enviar mensaje
          </button>
          <p class="form-privacy">
            <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Tu información es confidencial y nunca será compartida con terceros.
          </p>
        </div>

        <div class="success-msg" id="contactSuccess" style="display:none">
          <div class="success-icon">✓</div>
          <p class="success-title">¡Mensaje enviado!</p>
          <p class="success-desc">Te contactaremos en menos de 2 horas por WhatsApp o correo electrónico.</p>
        </div>
      </div>

      <!-- Info -->
      <div class="contact-info">

        <div class="info-card">
          <div class="info-icon">✉️</div>
          <div class="info-body">
            <p class="info-label">Correo electrónico</p>
            <a href="mailto:banamailing@gmail.com" class="info-value">banamailing@gmail.com</a>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">📞</div>
          <div class="info-body">
            <p class="info-label">Teléfono</p>
            <a href="tel:+51990137226" class="info-value">+51 990 137 226</a>
          </div>
        </div>

        <div class="info-card info-card-wa">
          <div class="info-icon">💬</div>
          <div class="info-body">
            <p class="info-label">WhatsApp — respuesta inmediata</p>
            <a href="https://api.whatsapp.com/send?phone=51990137226&text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20correos%20masivos%20en%20Per%C3%BA." target="_blank" class="info-value wa-link">Escribir al 990 137 226 →</a>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">📍</div>
          <div class="info-body">
            <p class="info-label">Ubicación</p>
            <p class="info-value">Chacarilla del Estanque,<br>Santiago de Surco, Lima — Perú</p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">🏢</div>
          <div class="info-body">
            <p class="info-label">Razón social</p>
            <p class="info-value">BANA NETWORK SAC<br><span class="info-ruc">RUC 20606350644</span></p>
          </div>
        </div>

        <div class="info-card">
          <div class="info-icon">🕐</div>
          <div class="info-body">
            <p class="info-label">Horario de atención</p>
            <p class="info-value">Lun – Vie: 9:00 am – 6:00 pm<br>Sáb: 9:00 am – 1:00 pm</p>
          </div>
        </div>

        <a href="https://api.whatsapp.com/send?phone=51990137226&text=Hola%2C%20necesito%20informaci%C3%B3n%20sobre%20correos%20masivos%20en%20Per%C3%BA." target="_blank" class="wa-cta-btn">
          <svg viewBox="0 0 32 32" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M16 .5C7.44.5.5 7.44.5 16c0 2.83.74 5.48 2.04 7.78L.5 31.5l7.93-2.07A15.45 15.45 0 0016 31.5C24.56 31.5 31.5 24.56 31.5 16S24.56.5 16 .5zm7.58 18.14c-.41-.2-2.44-1.2-2.82-1.34-.38-.14-.65-.2-.93.2-.28.41-1.07 1.34-1.31 1.62-.24.27-.48.31-.9.1-.41-.2-1.74-.64-3.32-2.04a12.4 12.4 0 01-2.3-2.85c-.24-.41-.03-.63.18-.84.19-.18.41-.48.62-.72.2-.24.27-.41.41-.69.14-.27.07-.52-.03-.72-.1-.2-.93-2.24-1.28-3.07-.33-.8-.67-.69-.93-.7h-.79c-.27 0-.72.1-1.1.52-.38.41-1.44 1.41-1.44 3.44s1.48 3.99 1.69 4.27c.2.27 2.9 4.43 7.04 6.21.98.42 1.75.68 2.35.87.99.31 1.88.27 2.59.16.79-.12 2.44-1 2.78-1.96.34-.96.34-1.78.24-1.96-.1-.18-.38-.27-.79-.48z"/></svg>
          Chatear por WhatsApp ahora
        </a>

      </div>
    </div>

    <!-- Map -->
    <div class="contact-map">
      <h3 class="map-title">¿Dónde estamos?</h3>
      <div class="map-wrap">
        <iframe
          title="Ubicación BanaMailing — Chacarilla del Estanque, Lima"
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3901.5!2d-76.9993!3d-12.1061!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x9105b7e1f2f2f2f3%3A0x0!2sChacarilla+del+Estanque%2C+Santiago+de+Surco%2C+Lima!5e0!3m2!1ses!2spe!4v1680000000000"
          width="100%" height="380" style="border:0;" allowfullscreen="" loading="lazy">
        </iframe>
      </div>
    </div>

  </div>
</section>

<style>
  .contact-section { background: #fff; padding: 4rem 2rem 5rem; }
  .contact-inner { max-width: 1180px; margin: 0 auto; }

  /* Header */
  .contact-header { text-align: center; margin-bottom: 3.5rem; }
  .contact-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--purple-light); border: 1px solid #DDD6FE;
    color: var(--purple); font-size: 12px; font-weight: 700;
    padding: 5px 16px; border-radius: 100px; margin-bottom: 1.25rem;
    text-transform: uppercase; letter-spacing: 0.05em;
  }
  .contact-title {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 900; letter-spacing: -0.04em;
    color: var(--text); line-height: 1.1; margin-bottom: 1rem;
  }
  .contact-title em { color: var(--purple); font-style: normal; }
  .contact-sub { font-size: 1rem; color: var(--muted); line-height: 1.7; max-width: 560px; margin: 0 auto; }

  /* Grid */
  .contact-grid {
    display: grid; grid-template-columns: 1.2fr 0.8fr;
    gap: 2.5rem; margin-bottom: 3.5rem; align-items: start;
  }

  /* Form card */
  .contact-form-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 20px; padding: 2rem 2rem;
    box-shadow: 0 2px 24px rgba(0,0,0,0.06);
  }
  .cfc-title { font-size: 1.15rem; font-weight: 800; color: var(--text); margin-bottom: 4px; }
  .cfc-sub { font-size: 13px; color: var(--muted); margin-bottom: 1.75rem; }

  .form-body { display: flex; flex-direction: column; gap: 1rem; }
  .field-row { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }

  select.field-input { cursor: pointer; }

  .contact-submit-btn {
    display: flex; align-items: center; justify-content: center; gap: 8px;
    background: var(--purple); color: #fff; border: none;
    padding: 14px 28px; border-radius: 10px;
    font-size: 15px; font-weight: 700; cursor: pointer; font-family: inherit;
    transition: background 0.15s, transform 0.15s, box-shadow 0.15s;
    box-shadow: 0 2px 12px rgba(103,76,196,0.28);
    width: 100%; margin-top: 0.25rem;
  }
  .contact-submit-btn:hover { background: var(--purple-dark); transform: translateY(-2px); box-shadow: 0 6px 24px rgba(103,76,196,0.35); }
  .form-privacy {
    display: flex; align-items: center; gap: 5px;
    font-size: 11.5px; color: #9CA3AF; text-align: center; justify-content: center;
  }

  /* Info panel */
  .contact-info { display: flex; flex-direction: column; gap: 12px; }

  .info-card {
    background: #fff; border: 1px solid var(--border);
    border-radius: 14px; padding: 1rem 1.25rem;
    display: flex; align-items: flex-start; gap: 12px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .info-card:hover { border-color: #DDD6FE; box-shadow: 0 4px 16px rgba(103,76,196,0.08); }
  .info-card-wa { border-color: #D1FAE5; background: #F0FDF4; }
  .info-card-wa:hover { border-color: #6EE7B7; }

  .info-icon {
    width: 40px; height: 40px; border-radius: 10px;
    background: var(--purple-light); display: flex; align-items: center;
    justify-content: center; font-size: 18px; flex-shrink: 0;
  }
  .info-card-wa .info-icon { background: #DCFCE7; }

  .info-body { flex: 1; }
  .info-label { font-size: 11px; font-weight: 700; color: var(--muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 3px; }
  .info-value { font-size: 13.5px; font-weight: 600; color: var(--text); text-decoration: none; line-height: 1.5; display: block; }
  .info-value:is(a):hover { color: var(--purple); }
  .info-ruc { font-size: 12px; font-weight: 500; color: var(--muted); }
  .wa-link { color: #16A34A !important; }
  .wa-link:hover { color: #15803D !important; }

  .wa-cta-btn {
    display: flex; align-items: center; justify-content: center; gap: 9px;
    background: #15803D; color: #fff;
    padding: 14px 20px; border-radius: 12px;
    font-size: 14.5px; font-weight: 700; text-decoration: none;
    transition: background 0.15s, transform 0.1s;
    box-shadow: 0 2px 12px rgba(37,211,102,0.3);
    margin-top: 4px;
  }
  .wa-cta-btn:hover { background: #166534; transform: translateY(-2px); }

  /* Map */
  .contact-map { }
  .map-title { font-size: 1rem; font-weight: 700; color: var(--text); margin-bottom: 1rem; }
  .map-wrap { border-radius: 16px; overflow: hidden; border: 1px solid var(--border); box-shadow: 0 2px 16px rgba(0,0,0,0.06); }

  @media (max-width: 900px) {
    .contact-section { padding: 3rem 1.25rem 4rem; }
    .contact-grid { grid-template-columns: 1fr; gap: 1.5rem; }
    .field-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  const btn = document.getElementById('contactSubmitBtn');
  btn?.addEventListener('click', () => {
    const nombre  = (document.getElementById('cNombre')  as HTMLInputElement)?.value.trim();
    const email   = (document.getElementById('cEmail')   as HTMLInputElement)?.value.trim();
    const tel     = (document.getElementById('cTel')     as HTMLInputElement)?.value.trim();
    const mensaje = (document.getElementById('cMensaje') as HTMLTextAreaElement)?.value.trim();

    if (!nombre || !email || !tel || !mensaje) {
      alert('Por favor completa los campos obligatorios (*).');
      return;
    }

    const formBody = document.getElementById('contactFormBody');
    const success  = document.getElementById('contactSuccess');
    if (formBody) formBody.style.display = 'none';
    if (success)  success.style.display  = 'block';
  });
</script>
