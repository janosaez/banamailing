---
const tiers = [
  {
    id: 'tier-10k',
    vol: '10,000',
    tag: 'Para empezar',
    featured: false,
    priceMes: 80,
    priceAnual: 64,
    totalAnual: 768,
    features: [
      'Hasta <strong>10,000 correos/mes</strong>',
      'PowerMTA + AMS Enterprise',
      'IPs de alta reputación <strong>(99% inbox)</strong>',
      'Reporte: aperturas, clics y rebotes',
      'Plantillas HTML incluidas',
      'Soporte por WhatsApp',
    ],
    waMsg: 'Hola%2C%20quiero%20el%20plan%2010.000%20correos%20de%20BanaMailing.',
  },
  {
    id: 'tier-50k',
    vol: '50,000',
    tag: 'Más popular',
    featured: true,
    priceMes: 280,
    priceAnual: 224,
    totalAnual: 2688,
    features: [
      'Hasta <strong>50,000 correos/mes</strong>',
      'PowerMTA + AMS Enterprise',
      'IPs de alta reputación <strong>(99% inbox)</strong>',
      'Reporte: aperturas, clics y rebotes',
      'Plantillas HTML incluidas',
      '<strong>3 dominios de envío</strong> incluidos',
      'Segmentación avanzada de listas',
      'Soporte por WhatsApp prioritario',
    ],
    waMsg: 'Hola%2C%20quiero%20el%20plan%2050.000%20correos%20de%20BanaMailing.',
  },
  {
    id: 'tier-125k',
    vol: '125,000',
    tag: 'Alto volumen',
    featured: false,
    priceMes: 590,
    priceAnual: 472,
    totalAnual: 5664,
    features: [
      'Hasta <strong>125,000 correos/mes</strong>',
      'PowerMTA + AMS Enterprise',
      'IPs de alta reputación <strong>(99% inbox)</strong>',
      'Reporte: aperturas, clics y rebotes',
      'Plantillas HTML incluidas',
      '<strong>5 dominios de envío</strong> incluidos',
      'Segmentación avanzada de listas',
      '<strong>Servidor dedicado</strong> para tus envíos',
      'Soporte por WhatsApp — respuesta en 1h',
    ],
    waMsg: 'Hola%2C%20quiero%20el%20plan%20125.000%20correos%20de%20BanaMailing.',
  },
];
---

<section class="plans-section" id="precios">
  <div class="plans-inner">

    <!-- Header -->
    <div class="plans-header">
      <div class="plans-eyebrow">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        Planes y Precios
      </div>
      <h2 class="plans-title">Precios claros,<br><em>sin letra chica</em></h2>
      <p class="plans-sub">Elige tu volumen mensual y forma de pago. Sin contratos ni permanencia.</p>

      <!-- Billing toggle -->
      <div class="billing-toggle" role="group" aria-label="Tipo de facturación">
        <button class="toggle-opt active" id="btn-mensual" aria-pressed="true" type="button">Mensual</button>
        <button class="toggle-opt" id="btn-anual" aria-pressed="false" type="button">
          Anual
          <span class="save-chip">Ahorra 20%</span>
        </button>
      </div>
    </div>

    <!-- Cards -->
    <div class="plans-grid">
      {tiers.map(t => (
        <div class={`plan-card${t.featured ? ' featured' : ''}`} id={t.id}>
          {t.featured && <div class="plan-badge">⭐ Más popular</div>}

          <div class="plan-top">
            <p class="plan-tag">{t.tag}</p>
            <p class="plan-vol"><strong>{t.vol}</strong> correos/mes</p>
          </div>

          <div class="plan-price-block">
            <!-- Monthly price -->
            <div class="price-mensual">
              <div class="plan-price">
                <span class="plan-cur">$</span>
                <span class="plan-num">{t.priceMes}</span>
                <span class="plan-period">/mes</span>
              </div>
              <p class="plan-setup">+ $49 de setup <span class="setup-note">(único pago)</span></p>
            </div>
            <!-- Annual price -->
            <div class="price-anual" style="display:none">
              <div class="plan-price">
                <span class="plan-cur">$</span>
                <span class="plan-num">{t.priceAnual}</span>
                <span class="plan-period">/mes</span>
              </div>
              <p class="plan-was">Antes <s>${t.priceMes}/mes</s> · Ahorra 20%</p>
              <p class="plan-annual-total">Total anual: <strong>${t.totalAnual}</strong> · Sin setup</p>
            </div>
          </div>

          <div class="plan-divider"></div>

          <ul class="plan-features">
            {t.features.map(f => (
              <li>
                <svg class="feat-chk" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="20 6 9 17 4 12"/></svg>
                <span set:html={f}></span>
              </li>
            ))}
          </ul>

          <a
            href={`https://api.whatsapp.com/send?phone=51990137226&text=${t.waMsg}`}
            target="_blank" rel="noopener noreferrer"
            class={`plan-cta${t.featured ? ' plan-cta-solid' : ' plan-cta-outline'}`}
          >
            Contratar plan →
          </a>
        </div>
      ))}
    </div>

    <p class="plans-footer">
      ¿Necesitas más de 125,000 correos? <a href="https://api.whatsapp.com/send?phone=51990137226&text=Hola%2C%20necesito%20un%20plan%20personalizado%20de%20BanaMailing." target="_blank" rel="noopener noreferrer" class="plans-link">Contáctanos para un plan a medida →</a>
    </p>

  </div>
</section>

<script>
  const btnMensual = document.getElementById('btn-mensual') as HTMLButtonElement;
  const btnAnual   = document.getElementById('btn-anual')   as HTMLButtonElement;

  function setBilling(mode: 'mensual' | 'anual') {
    const isMensual = mode === 'mensual';

    btnMensual.classList.toggle('active', isMensual);
    btnMensual.setAttribute('aria-pressed', String(isMensual));
    btnAnual.classList.toggle('active', !isMensual);
    btnAnual.setAttribute('aria-pressed', String(!isMensual));

    document.querySelectorAll<HTMLElement>('.price-mensual').forEach(el => {
      el.style.display = isMensual ? '' : 'none';
    });
    document.querySelectorAll<HTMLElement>('.price-anual').forEach(el => {
      el.style.display = isMensual ? 'none' : '';
    });
  }

  btnMensual.addEventListener('click', () => setBilling('mensual'));
  btnAnual.addEventListener('click',   () => setBilling('anual'));
</script>

<style>
  /* ── Section ── */
  .plans-section {
    background: #F8F7FF;
    padding: 5rem 4rem;
    border-top: 1px solid var(--border);
  }
  .plans-inner { max-width: 1100px; margin: 0 auto; }

  /* ── Header ── */
  .plans-header { text-align: center; margin-bottom: 3rem; }
  .plans-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--purple-light); color: var(--purple);
    border: 1px solid #DDD6FE;
    font-size: 12px; font-weight: 700;
    padding: 5px 16px; border-radius: 100px;
    margin-bottom: 1.25rem;
    text-transform: uppercase; letter-spacing: 0.06em;
  }
  .plans-title {
    font-size: clamp(1.8rem, 3vw, 2.6rem);
    font-weight: 900; letter-spacing: -0.035em;
    color: var(--text); margin-bottom: 0.6rem; line-height: 1.1;
  }
  .plans-title em { color: var(--purple); font-style: normal; }
  .plans-sub { font-size: 1rem; color: var(--muted); margin-bottom: 2rem; }

  /* ── Toggle ── */
  .billing-toggle {
    display: inline-flex;
    background: #EDE9FF;
    border-radius: 100px;
    padding: 4px;
    gap: 4px;
  }
  .toggle-opt {
    position: relative;
    display: inline-flex; align-items: center; gap: 8px;
    padding: 9px 22px;
    border-radius: 100px;
    border: none; cursor: pointer;
    font-size: 14px; font-weight: 600;
    font-family: inherit;
    color: var(--muted);
    background: transparent;
    transition: background 0.2s, color 0.2s;
  }
  .toggle-opt.active {
    background: #fff;
    color: var(--text);
    box-shadow: 0 1px 6px rgba(0,0,0,0.12);
  }
  .save-chip {
    background: #16A34A;
    color: #fff;
    font-size: 10px; font-weight: 700;
    padding: 2px 8px; border-radius: 100px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  /* ── Grid ── */
  .plans-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
    align-items: start;
  }

  /* ── Card ── */
  .plan-card {
    background: #fff;
    border: 1.5px solid var(--border);
    border-radius: 20px;
    padding: 2rem 1.75rem;
    display: flex; flex-direction: column;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }
  .plan-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 14px 40px rgba(103,76,196,0.12);
    border-color: #DDD6FE;
  }
  .plan-card.featured {
    border: 2px solid var(--purple);
    box-shadow: 0 8px 32px rgba(103,76,196,0.18);
  }
  .plan-card.featured:hover {
    transform: translateY(-7px);
    box-shadow: 0 20px 52px rgba(103,76,196,0.25);
  }

  /* Badge */
  .plan-badge {
    position: absolute; top: -14px; left: 50%;
    transform: translateX(-50%);
    background: var(--purple); color: #fff;
    font-size: 11px; font-weight: 700;
    padding: 4px 16px; border-radius: 100px;
    white-space: nowrap; letter-spacing: 0.04em;
  }

  /* Top */
  .plan-top { margin-bottom: 1.5rem; }
  .plan-tag {
    font-size: 11px; font-weight: 700; text-transform: uppercase;
    letter-spacing: 0.08em; color: var(--muted); margin-bottom: 0.4rem;
  }
  .plan-card.featured .plan-tag { color: var(--purple); }
  .plan-vol { font-size: 1.05rem; color: var(--text); }
  .plan-vol strong { font-weight: 900; font-size: 1.15rem; letter-spacing: -0.02em; }

  /* Price block */
  .plan-price-block { margin-bottom: 0.25rem; }
  .plan-price {
    display: flex; align-items: baseline; gap: 3px;
    line-height: 1; margin-bottom: 6px;
  }
  .plan-cur { font-size: 1.1rem; font-weight: 700; color: var(--muted); }
  .plan-num {
    font-size: 3rem; font-weight: 900;
    letter-spacing: -0.05em; color: var(--text);
  }
  .plan-period { font-size: 0.9rem; font-weight: 500; color: var(--muted); }
  .plan-setup { font-size: 12px; color: var(--muted); }
  .setup-note { font-style: italic; }
  .plan-was { font-size: 12px; color: var(--muted); margin-bottom: 3px; }
  .plan-was s { opacity: 0.6; }
  .plan-annual-total { font-size: 12px; color: var(--purple); font-weight: 600; }

  /* Divider */
  .plan-divider { height: 1px; background: var(--border); margin: 1.5rem 0; }

  /* Features */
  .plan-features {
    list-style: none;
    display: flex; flex-direction: column; gap: 10px;
    flex: 1; margin-bottom: 1.75rem;
  }
  .plan-features li {
    display: flex; align-items: flex-start; gap: 10px;
    font-size: 13.5px; color: var(--text); line-height: 1.5;
  }
  .feat-chk {
    flex-shrink: 0; margin-top: 2px;
    color: var(--purple);
  }
  .plan-card.featured .feat-chk { color: var(--purple); }

  /* CTA */
  .plan-cta {
    display: block; width: 100%;
    padding: 13px; border-radius: 10px;
    font-size: 14px; font-weight: 700;
    text-align: center; text-decoration: none;
    transition: background 0.15s, transform 0.1s, box-shadow 0.15s;
    margin-top: auto;
  }
  .plan-cta-outline {
    background: #fff; color: var(--purple);
    border: 1.5px solid #DDD6FE;
  }
  .plan-cta-outline:hover {
    background: var(--purple-light);
    border-color: var(--purple);
  }
  .plan-cta-solid {
    background: var(--purple); color: #fff;
    border: 1.5px solid transparent;
    box-shadow: 0 4px 16px rgba(103,76,196,0.3);
  }
  .plan-cta-solid:hover {
    background: var(--purple-dark);
    transform: translateY(-1px);
    box-shadow: 0 8px 24px rgba(103,76,196,0.4);
  }

  /* Footer */
  .plans-footer {
    text-align: center; margin-top: 2.5rem;
    font-size: 13px; color: var(--muted);
  }
  .plans-link { color: var(--purple); font-weight: 600; text-decoration: none; }
  .plans-link:hover { text-decoration: underline; }

  /* Mobile */
  @media (max-width: 900px) {
    .plans-section { padding: 3.5rem 1.5rem; }
    .plans-grid { grid-template-columns: 1fr; }
    .plan-card.featured { margin-top: 1rem; }
    .billing-toggle { width: 100%; justify-content: center; }
  }
</style>
