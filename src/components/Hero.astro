---
---
<section class="hero">
  <svg class="hero-blob" viewBox="0 0 700 700" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
    <defs>
      <radialGradient id="g1" cx="55%" cy="35%" r="60%">
        <stop offset="0%" stop-color="#EDE9FF" stop-opacity="1"/>
        <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
      </radialGradient>
      <radialGradient id="g2" cx="30%" cy="75%" r="50%">
        <stop offset="0%" stop-color="#F3F0FF" stop-opacity="0.8"/>
        <stop offset="100%" stop-color="#ffffff" stop-opacity="0"/>
      </radialGradient>
    </defs>
    <ellipse cx="420" cy="280" rx="400" ry="340" fill="url(#g1)"/>
    <ellipse cx="300" cy="520" rx="260" ry="210" fill="url(#g2)"/>
  </svg>

  <div class="hero-grid">
    <div class="hero-left">
      <div class="badge">
        <span class="badge-dot"></span>
        Servicio activo en Perú
      </div>

      <h1>
        <span class="accent">BanaMailing correos masivos</span><br>
        en Perú y email marketing profesional
      </h1>

      <h2 class="hero-sub">
        En <strong>BanaMailing</strong> ayudamos a empresas con <strong>campañas de mailing y correos masivos Perú</strong>, logrando tasas de apertura superiores al 40% gracias a una segmentación avanzada, IPs y dominios de alta reputación, y servidores optimizados para una máxima entregabilidad.
      </h2>

      <div class="stats-row">
        <div class="stat">
          <span class="stat-n"><em>+40</em>%</span>
          <span class="stat-l">Tasa de apertura</span>
        </div>
        <div class="stat">
          <span class="stat-n"><em>99</em>%</span>
          <span class="stat-l">Entregabilidad</span>
        </div>
        <div class="stat">
          <span class="stat-n"><em>+500</em></span>
          <span class="stat-l">Empresas en Perú</span>
        </div>
      </div>

      <div class="cta-group">
        <button class="btn-p" onclick="document.getElementById('demo').scrollIntoView({behavior:'smooth'})">
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.22 2.18 2 2 0 012.18 0h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.09 7.91a16 16 0 006 6l1.27-1.27a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 14.92z"/></svg>
          Hablar con un experto
        </button>
        <button class="btn-s" onclick="document.getElementById('demo').scrollIntoView({behavior:'smooth'})">Ver demo gratis →</button>
      </div>

      <p class="trust">
        <svg width="14" height="14" viewBox="0 0 20 20" fill="currentColor" class="trust-ok" aria-hidden="true"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414L8.414 15l-4.121-4.121a1 1 0 011.414-1.414L8.414 12.17l6.879-6.88a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
        Sin compromiso &nbsp;·&nbsp; Solo resultados reales
      </p>
    </div>

    <div class="hero-right">
      <div class="rate-card">
        <div class="rc-header">
          <span class="rc-label">Tasa de apertura promedio</span>
          <span class="rc-val">42.3%</span>
        </div>
        <div class="rc-track"><div class="rc-fill" id="bar"></div></div>
        <div class="rc-compare">
          <span class="good">● BanaMailing: 42%</span>
          <span class="avg">● Industria: 18%</span>
        </div>
      </div>

      <div class="feature-card">
        <div class="fc-icon">📬</div>
        <div class="fc-body">
          <p class="fc-title">IPs y dominios de alta reputación</p>
          <p class="fc-desc">Infraestructura calificada para evitar spam y maximizar la entregabilidad en cada campaña.</p>
        </div>
        <span class="fc-pill">99% inbox</span>
      </div>

      <div class="feature-card">
        <div class="fc-icon">🎯</div>
        <div class="fc-body">
          <p class="fc-title">Segmentación avanzada de listas</p>
          <p class="fc-desc">Segmenta por industria, comportamiento y geografía para mayor relevancia y conversión.</p>
        </div>
        <span class="fc-pill">+CTR</span>
      </div>

      <div class="feature-card">
        <div class="fc-icon">📊</div>
        <div class="fc-body">
          <p class="fc-title">Reportes en tiempo real</p>
          <p class="fc-desc">Métricas de aperturas, clics y conversiones disponibles desde el primer envío.</p>
        </div>
        <span class="fc-pill">Dashboard</span>
      </div>
    </div>
  </div>
</section>

<style>
  .hero { background:#fff; padding:5.5rem 4rem 5rem; height:calc(100vh - 68px); max-height:820px; min-height:560px; display:flex; align-items:center; position:relative; overflow:hidden; }
  .hero-blob { position:absolute; right:0; top:0; width:55%; height:100%; pointer-events:none; z-index:0; }
  .hero-grid { position:relative; z-index:2; display:grid; grid-template-columns:1.1fr 0.9fr; gap:5rem; align-items:center; max-width:1180px; margin:0 auto; width:100%; }
  .badge { display:inline-flex; align-items:center; gap:7px; background:var(--purple-light); border:1px solid #DDD6FE; color:var(--purple); font-size:12px; font-weight:600; padding:5px 14px; border-radius:100px; margin-bottom:1.5rem; letter-spacing:0.01em; }
  .badge-dot { width:7px; height:7px; background:var(--green); border-radius:50%; animation:blink 2s infinite; }
  h1 { font-size:clamp(2.1rem,3.8vw,3.3rem); font-weight:900; line-height:1.08; color:var(--text); letter-spacing:-0.04em; margin-bottom:1.25rem; }
  h1 .accent { color:var(--purple); }
  .hero-sub { font-size:1rem; font-weight:400; color:var(--muted); line-height:1.72; margin-bottom:2.25rem; max-width:500px; }
  .hero-sub strong { color:var(--text); font-weight:600; }
  .stats-row { display:flex; gap:2.5rem; margin-bottom:2.5rem; padding-bottom:2rem; border-bottom:1px solid var(--border); }
  .stat { display:flex; flex-direction:column; }
  .stat-n { font-size:2rem; font-weight:800; color:var(--text); letter-spacing:-0.04em; line-height:1; }
  .stat-n em { color:var(--purple); font-style:normal; }
  .stat-l { font-size:12px; color:var(--muted); margin-top:5px; font-weight:500; }
  .cta-group { display:flex; align-items:center; gap:12px; margin-bottom:1.25rem; }
  .btn-p { background:var(--purple); color:#fff; border:none; padding:14px 28px; border-radius:10px; font-size:15px; font-weight:700; cursor:pointer; font-family:inherit; display:flex; align-items:center; gap:8px; transition:background 0.15s,transform 0.15s,box-shadow 0.15s; box-shadow:0 2px 12px rgba(103,76,196,0.28); }
  .btn-p:hover { background:var(--purple-dark); transform:translateY(-2px); box-shadow:0 6px 24px rgba(103,76,196,0.38); }
  .btn-s { background:#fff; color:var(--text); border:1px solid var(--border); padding:14px 24px; border-radius:10px; font-size:15px; font-weight:600; cursor:pointer; font-family:inherit; transition:border-color 0.15s,background 0.15s; }
  .btn-s:hover { border-color:#9CA3AF; background:#FAFAFA; }
  .trust { display:flex; align-items:center; gap:6px; font-size:12.5px; color:var(--muted); font-weight:500; }
  .trust-ok { color:var(--green); }
  .hero-right { display:flex; flex-direction:column; gap:12px; }
  .rate-card { background:#fff; border:1px solid var(--border); border-radius:16px; padding:1.25rem 1.5rem; box-shadow:0 1px 8px rgba(0,0,0,0.06); }
  .rc-header { display:flex; justify-content:space-between; align-items:baseline; margin-bottom:10px; }
  .rc-label { font-size:11.5px; color:var(--muted); font-weight:500; text-transform:uppercase; letter-spacing:0.06em; }
  .rc-val { font-size:1.5rem; font-weight:800; color:var(--purple); letter-spacing:-0.03em; }
  .rc-track { height:7px; background:var(--purple-light); border-radius:100px; overflow:hidden; margin-bottom:8px; }
  .rc-fill { height:100%; background:var(--purple); border-radius:100px; width:0%; transition:width 2s cubic-bezier(0.4,0,0.2,1); }
  .rc-compare { display:flex; justify-content:space-between; font-size:11.5px; font-weight:500; }
  .rc-compare .good { color:var(--purple); }
  .rc-compare .avg { color:var(--muted); }
  .feature-card { background:#fff; border:1px solid var(--border); border-radius:14px; padding:1rem 1.25rem; display:flex; align-items:flex-start; gap:12px; transition:border-color 0.2s,box-shadow 0.2s,transform 0.2s; box-shadow:0 1px 4px rgba(0,0,0,0.04); }
  .feature-card:hover { border-color:#DDD6FE; box-shadow:0 4px 18px rgba(103,76,196,0.1); transform:translateY(-2px); }
  .fc-icon { width:38px; height:38px; border-radius:10px; background:var(--purple-light); display:flex; align-items:center; justify-content:center; font-size:17px; flex-shrink:0; }
  .fc-body { flex:1; }
  .fc-title { font-size:14px; font-weight:700; color:var(--text); margin-bottom:3px; }
  .fc-desc { font-size:12.5px; color:var(--muted); line-height:1.5; }
  .fc-pill { background:#F0FDF4; color:var(--green); border:1px solid #BBF7D0; font-size:11px; font-weight:700; padding:3px 10px; border-radius:100px; white-space:nowrap; flex-shrink:0; align-self:center; }
  @media(max-width:900px){ .hero{padding:3rem 1.5rem 2.5rem;height:auto;min-height:auto} .hero-grid{grid-template-columns:1fr;gap:2.5rem} }
</style>

<script>
  setTimeout(() => {
    const bar = document.getElementById('bar');
    if (bar) bar.style.width = '42.3%';
  }, 500);
</script>
