---
const logos = [
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/INEI-ra6ic15ovlbiidsc3wte13ibzvmcm61ivqn4xh5mqk.png', alt: 'INEI', keep: true },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/Logo-Universidad-Adolfo-Ibanez-ra6ic15ovlbiidsc3wte13ibzvmcm61ivqn4xh5mqk.jpg', alt: 'Universidad Adolfo Ibáñez' },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/papachay-market-r7ev9sro26afrsgrbxftyo6431th1a36kmnmd1rr6k.png', alt: 'Papachay Market' },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/PS-COURIER-r7ev9tpi90bq3efe6fugj5xkofou8z6wwrb3ubqd0c.png', alt: 'PS Courier' },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/AELE-r7ev9uncfud0f0e10y933np19tk7goan8vylbloyu4.png', alt: 'AELE' },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/cuy-arts-r7ev9vl6moeaqmcnvgnpo5ghv7fkodedl0m2svnkak.png', alt: 'Cuy Arts', small: true },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/hamkacafe-1-r7exfbihpaera1v1nxr63lxns1q8umu8wbk87ktw0s.png', alt: 'Hamka Cafe', keep: true },
  { src: 'https://banamailing.com/wp-content/uploads/elementor/thumbs/punto7-r7exitgv5376hss38g76dq5fdohfi2qa1mzainn4v0.jpg', alt: 'Punto 7' },
];
---
<section class="logos-scroll-section">
  <p class="logos-scroll-label">Empresas que confían en BanaMailing</p>
  <div class="logos-track-wrap">
    <div class="logos-track">
      {logos.map(l => { const h = l.small ? 39 : l.keep ? 52 : 78; const w = l.small ? 100 : l.keep ? 140 : 200; return <div class={`logo-slide${l.small ? ' logo-small' : l.keep ? '' : ' logo-big'}`}><img src={l.src} alt={l.alt} loading="lazy" width={w} height={h} decoding="async" /></div>; })}
      {logos.map(l => { const h = l.small ? 39 : l.keep ? 52 : 78; const w = l.small ? 100 : l.keep ? 140 : 200; return <div class={`logo-slide${l.small ? ' logo-small' : l.keep ? '' : ' logo-big'}`}><img src={l.src} alt={l.alt} loading="lazy" width={w} height={h} decoding="async" /></div>; })}
    </div>
  </div>
</section>

<style>
  .logos-scroll-section { background:#fff; border-top:1px solid var(--border); border-bottom:1px solid var(--border); padding:2.5rem 0; overflow:hidden; }
  .logos-scroll-label { text-align:center; font-size:12px; font-weight:700; color:#9CA3AF; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:1.75rem; }
  .logos-track-wrap { overflow:hidden; position:relative; mask-image:linear-gradient(to right,transparent 0%,black 10%,black 90%,transparent 100%); -webkit-mask-image:linear-gradient(to right,transparent 0%,black 10%,black 90%,transparent 100%); }
  .logos-track { display:flex; align-items:center; width:max-content; animation:logoScroll 28s linear infinite; }
  .logos-track:hover { animation-play-state:paused; }
  .logo-slide { padding:0 3rem; display:flex; align-items:center; justify-content:center; flex-shrink:0; border-right:1px solid var(--border); }
  .logo-slide:last-child { border-right:none; }
  .logo-slide img { height:52px; width:auto; max-width:140px; object-fit:contain; filter:grayscale(100%) opacity(0.55); transition:filter 0.3s ease,transform 0.3s ease; }
  .logo-slide img:hover { filter:grayscale(0%) opacity(1); transform:scale(1.08); }
  .logo-big img { height:78px; max-width:200px; }
  .logo-small img { height:39px; max-width:100px; }
  @media(max-width:900px){ .logo-slide{padding:0 1.75rem} .logo-slide img{height:38px;max-width:100px} .logo-big img{height:57px;max-width:140px} .logo-small img{height:28px;max-width:70px} }
</style>
