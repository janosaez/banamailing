    <div class="reviews-track-wrap">
      <button class="rv-arrow rv-prev" id="rvPrev" aria-label="Anterior">‹</button>
      <div class="reviews-track" id="reviewsTrack">

        <div class="rv-card">
          <div class="rv-top">
            <div class="rv-avatar" style="background:#2E7D32;">E</div>
