<style>
  .site-footer {
    background: #0E0B1A;
    color: rgba(255,255,255,0.75);
    padding: 4rem 4rem 0;
  }
  .footer-inner { max-width: 1180px; margin: 0 auto; }

  .footer-top {
    display: grid;
    grid-template-columns: 1.8fr 1fr 1fr 1.2fr;
    gap: 3rem; padding-bottom: 3rem;
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .footer-logo {
    font-size: 1.3rem; font-weight: 900;
    color: #fff; letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }
  .footer-about { font-size: 13px; line-height: 1.7; color: rgba(255,255,255,0.55); }
  .footer-about strong { color: rgba(255,255,255,0.85); font-weight: 600; }
  .footer-social { display: flex; gap: 8px; margin-top: 1.25rem; }
  .social-btn {
    width: 36px; height: 36px; border-radius: 9px;
    background: rgba(255,255,255,0.08); color: rgba(255,255,255,0.7);
    display: flex; align-items: center; justify-content: center;
    text-decoration: none; transition: background 0.15s, color 0.15s;
  }
  .social-btn:hover { background: rgba(255,255,255,0.16); color: #fff; }
  .social-wa:hover { background: #25D366; color: #fff; }

  .footer-col-title {
    font-size: 12px; font-weight: 800; color: #fff;
    text-transform: uppercase; letter-spacing: 0.08em;
    margin-bottom: 1.1rem;
  }
  .footer-links { list-style: none; display: flex; flex-direction: column; gap: 8px; }
  .footer-links a {
    font-size: 13.5px; color: rgba(255,255,255,0.55);
    text-decoration: none; transition: color 0.15s;
  }
  .footer-links a:hover { color: #fff; }

  .footer-contact-list { list-style: none; display: flex; flex-direction: column; gap: 10px; margin-bottom: 1.25rem; }
  .footer-contact-list li { display: flex; align-items: flex-start; gap: 9px; font-size: 13px; color: rgba(255,255,255,0.55); }
  .footer-contact-list a { color: rgba(255,255,255,0.7); text-decoration: none; transition: color 0.15s; }
  .footer-contact-list a:hover { color: #fff; }
  .fc-ico { flex-shrink: 0; font-size: 14px; margin-top: 1px; }
  .fc-legal { color: rgba(255,255,255,0.85); font-weight: 700; font-size: 13px; }
  .footer-wa-btn {
    display: inline-flex; align-items: center; gap: 7px;
    background: #15803D; color: #fff;
    padding: 9px 16px; border-radius: 9px;
    font-size: 13px; font-weight: 700; text-decoration: none;
    transition: background 0.15s, transform 0.1s;
  }
  .footer-wa-btn:hover { background: #166534; transform: translateY(-1px); }

  .footer-map-wrap {
    border-radius: 12px; overflow: hidden;
    margin: 2.5rem 0;
    border: 1px solid rgba(255,255,255,0.08);
  }

  .footer-bottom {
    padding: 1.5rem 0;
    border-top: 1px solid rgba(255,255,255,0.06);
    display: flex; align-items: center; justify-content: space-between;
    flex-wrap: wrap; gap: 0.75rem;
    font-size: 12px; color: rgba(255,255,255,0.65);
  }
  .footer-bottom strong { color: rgba(255,255,255,0.8); font-weight: 600; }
  .footer-bottom-links { display: flex; gap: 1.5rem; }
  .footer-bottom-links a { color: rgba(255,255,255,0.65); text-decoration: none; transition: color 0.15s; }
  .footer-bottom-links a:hover { color: #fff; }

  @media (max-width: 900px) {
    .site-footer { padding: 3rem 1.5rem 0; }
    .footer-top { grid-template-columns: 1fr; gap: 2rem; }
    .footer-bottom { flex-direction: column; text-align: center; }
  }
</style>
