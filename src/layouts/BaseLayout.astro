---
import Footer from '../components/Footer.astro';
interface Props { title?: string; description?: string; }
const {
  title = 'BanaMailing — Correos Masivos en Perú | Email Marketing Profesional',
  description = 'En BanaMailing ayudamos a empresas con campañas de mailing y correos masivos Perú, logrando tasas de apertura superiores al 40%.'
} = Astro.props;
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <!-- Preload Inter variable font (latin) to break CSS→font render chain -->
  <link rel="preload" href="/_astro/files/inter-latin-wght-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
  <link rel="preload" href="/_astro/files/inter-latin-ext-wght-normal.woff2" as="font" type="font/woff2" crossorigin="anonymous" />
</head>
<body>
  <slot />
  <Footer />
</body>
</html>

<style is:global>
  @import '../styles/global.css';
</style>
